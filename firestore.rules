rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Politicos - leitura publica
    match /deputados/{docId} {
      allow read: if true;
      allow write: if false;
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    match /deputados_federais/{docId} {
      allow read: if true;
      allow write: if false;
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    match /senadores/{docId} {
      allow read: if true;
      allow write: if false;
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    match /governadores/{docId} {
      allow read: if true;
      allow write: if false;
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    match /deputados_distritais/{docId} {
      allow read: if true;
      allow write: if false;
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    // Denuncias - leitura publica, escrita autenticada
    match /denuncias/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Fornecedores - leitura publica
    match /fornecedores/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Purchases - apenas leitura pelo próprio usuário
    match /purchases/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    // Chats - apenas leitura pelo próprio usuário
    match /chats/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    // Analyses - apenas leitura pelo próprio usuário
    match /analyses/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    // Presencas - leitura pública, escrita via Cloud Function
    match /presencas/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Proposicoes - leitura pública
    match /proposicoes/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Politicians (collection usada pela ingestão)
    match /politicians/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // REGRA DEFAULT: negar tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
